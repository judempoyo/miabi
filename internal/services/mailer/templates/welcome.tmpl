{{ define "content" }}
<h2 style="color: #111827; font-size: 20px; line-height: 1.3; margin: 0 0 18px; font-weight: 700; letter-spacing: -0.01em;">Welcome to {{ .AppName }}</h2>
<p style="margin: 0 0 16px;">Hi {{ .UserName }},</p>
<p class="lead" style="margin: 0 0 16px; font-size: 15px; color: #4b5563;">An account has been created for you on {{ .AppName }}. You can now deploy applications, connect domains with automatic SSL, provision databases, and manage everything from one place.</p>

<table class="stats-table" role="presentation" style="width: 100%; border-collapse: separate; border-spacing: 0; margin: 20px 0; border: 1px solid #eceef2; border-radius: 10px; overflow: hidden;">
  <tr>
    <td style="padding: 12px 16px; text-align: left; border-bottom: 1px solid #eceef2; font-size: 14px; color: #111827;"><strong>1.</strong>&nbsp; Sign in and create or join a workspace</td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; text-align: left; border-bottom: 1px solid #eceef2; font-size: 14px; color: #111827;"><strong>2.</strong>&nbsp; Deploy your first application from Git, an image, or a template</td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; text-align: left; font-size: 14px; color: #111827;"><strong>3.</strong>&nbsp; Connect a domain and get automatic SSL</td>
  </tr>
</table>

{{ if .LoginURL }}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 28px auto;">
  <tr><td align="center" bgcolor="#9333ea" style="border-radius: 8px;">
    <a href="{{ .LoginURL }}" class="btn" style="display: inline-block; padding: 13px 30px; background-color: #9333ea; color: #ffffff !important; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 15px; line-height: 1;">Sign in</a>
  </td></tr>
</table>
{{ end }}

<div class="divider" style="height: 1px; line-height: 1px; font-size: 1px; background-color: #eceef2; margin: 28px 0;"></div>
<p class="muted" style="margin: 0 0 16px; color: #6b7280; font-size: 13px;">If you weren't given a password, use the <strong>Forgot password</strong> link on the sign-in page to set one. If you didn't expect this account, you can safely ignore this email.</p>
{{ end }}
