# Miabi — full-featured single-node example. Copy to .env and edit.
#
# Generate strong secrets:
#   openssl rand -hex 32
# Docker socket group (so the non-root image can reach the daemon):
#   echo "DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)" >> .env

# --- Domains ---------------------------------------------------------------
# Panel domain (Goma issues its cert; this is also the CORS allowlist).
MIABI_DOMAIN=miabi.example.com
MIABI_WEB_URL=https://miabi.example.com
# ACME contact for issued certificates.
MIABI_ACME_EMAIL=admin@example.com

# --- Secrets (production refuses to start on defaults) ---------------------
MIABI_JWT_SECRET=
MIABI_ENCRYPTION_KEY=
MIABI_ADMIN_EMAIL=admin@example.com
MIABI_ADMIN_PASSWORD=

# --- Datastores ------------------------------------------------------------
MIABI_DB_USER=miabi
MIABI_DB_PASSWORD=
MIABI_DB_NAME=miabi
MIABI_REDIS_PASSWORD=

# Host docker group id (see the command above). 999 is a common default.
DOCKER_GID=999

# --- One-click public app URLs (wildcard domain) ---------------------------
# Apps get a URL under this base domain; point *.apps.example.com at this host.
# The provider is the Goma certManager provider used for those certs ("" = default).
MIABI_EXTERNAL_BASE_DOMAIN=apps.example.com
MIABI_EXTERNAL_BASE_PROVIDER=

# --- Built-in container registry (git-source builds push here) -------------
# Required for git-source app deploys and pipeline builds: the runner builds the
# image and pushes it here for the node to pull. Host defaults to
# registry.<MIABI_EXTERNAL_BASE_DOMAIN>; the platform token is derived from the
# encryption key, so no separate secret is needed.
# NOTE: the built-in registry requires the Goma gateway (compose.yaml). On the
# compose.traefik.yaml variant set this to false and use an external registry.
MIABI_REGISTRY_ENABLED=true
MIABI_REGISTRY_HOST=
MIABI_REGISTRY_STORAGE=filesystem

# --- Runners (build/pipeline machines) -------------------------------------
# Every build runs on a registered runner — add one from Settings → Runners
# (the panel shows the `docker run … miabi/runner` enrollment command). No runner
# is defined here because runners dial OUT to the panel; they can live anywhere.
MIABI_RUNNER_IMAGE=miabi/runner:latest
MIABI_RUNNER_WAIT_TIMEOUT_MINUTES=30

# --- Log store -------------------------------------------------------------
# Externalized to the miabi-logs volume by default (see compose.yaml). Override:
# MIABI_LOG_BACKEND=filesystem        # filesystem | off
# MIABI_LOG_RETENTION_DAYS=30         # 0 = keep forever

# --- Platform email (optional) ---------------------------------------------
# When set, Miabi sends password-reset / invitation / welcome emails.
MIABI_APP_NAME=Miabi
MIABI_SMTP_HOST=
MIABI_SMTP_PORT=587
MIABI_SMTP_USERNAME=
MIABI_SMTP_PASSWORD=
MIABI_SMTP_FROM=
MIABI_SMTP_ENCRYPTION=starttls

# --- Enterprise license (optional; community runs without one) -------------
MIABI_LICENSE_PUBLIC_KEY=
MIABI_LICENSE_FILE=

# --- Image override --------------------------------------------------------
MIABI_IMAGE=miabi/miabi:latest
